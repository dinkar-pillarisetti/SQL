DATEADD --> SYNTAX :- DATEADD(part,interval,date)
example :- DATEADD(year,2,orderdate)  adding 2 years
DATEADD(year,-4, orderdate)  subtracting 4 years

SELECT
OrderID,
OrderDate,
DATEADD(DAY,-10,OrderDate) AS "10DAYS_BEFORE",
DATEADD(MONTH,2,OrderDate) AS "2MONTHS_SlATER",
DATEADD(YEAR,3,OrderDate) AS "3YEARSlATER"
FROM
SalesDB.Sales.Orders


DATEDIFF :- DATE DIFFERENCE BETWEEN 2 DATES SYNTAX :- DATEDIFF(part,start_date,end_date)

SELECT 
FirstName,
BirthDate,
DATEDIFF(year,BirthDate,getdate()) as age
FROM
Sales.Employees

SELECT
OrderDate,
ShipDate,
DATEDIFF(day,OrderDate,ShipDate) day2sip
FROM
Sales.Orders

Find the no of days between last order and previous order (Time Gap analysis) 

SELECT
OrderID,
OrderDate 'current_order_date',
LAG(orderdate) over(ORDER BY OrderDate) 'PRVIOUS_ORDER_DATE',
DATEDIFF(DAY,LAG(orderdate) over(ORDER BY OrderDate),OrderDate) AS 'DAYSDIFFERENCE'
FROM
Sales.Orders


