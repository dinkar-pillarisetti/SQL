NULL is nothing, it doesn't have any value.

ISNULL, COALESCE are used for replacing the null 
IS NULL & IS NOT NULL --->is used to check NULL or not


i. ISNULL ---> is used to replace null with specific value. syntax :- ISNULL(value,replacing value)
EXAMPLE --> ISNULL(shippingaddress,'Unknown')
ISNULL(shippingaddress,billingaddress)

ii.COALESCE ---> is used to replace null values with specific values. syntax:- COALESCE(value1,value2,value3,......value-n)
example:- COALESCE(shippingaddress,billingaddress,'N/A')

ISNULL IS FAST,COALESCE IS SLOW

ISNULL --> SQLSERVER
nvl  --->oracle
ifnull --->mysql

iii. Handling NULL in Data Aggregation -->  aggregation functions like count(sales),sum(),max(),min() will skips null value column 
rows from calculation. --> to overcome that first replace null with '0' then apply aggregation operation.

SELECT
CustomerID,
Score,
COALESCE(SCORE,0),
AVG(SCORE) OVER() AS 'AVG_SCORE',
AVG(COALESCE(score,0)) OVER() AS 'avg_score2'
FROM
Sales.Customers

iv. Handling NULLs in Mathematical functions -->   NULL + 5 =  NULL 

--Display full names of customers
-- Add 10 points to the score

SELECT
FirstName,LastName,Score,
FirstName+' '+coalesce(LastName,''),
coalesce(score,0)+10 as 'new_score'
FROM
Sales.Customers


v. Handling NULLs in Joins ---> Always eliminate NULLs in key columns while joining data. solution is need to replace NULLS with
'' and join tables while joining tables.

SELECT a.year,a.type,a.orders,b.sales FROM 
Table1 a JOIN 
Table2 b on a.year = b.year AND ISNULL(a.type) = ISNULL(b.type)

vi. Handling NULLs Sorting data  --->  15,50,NULL ---> in Ascedning order --> NULL->15->50 ( NULL is lowest preference)
descedning order --> 50->15->NULL 

SELECT
CustomerID,score,
CASE WHEN Score IS NULL THEN 1 ELSE 0 END
FROM
Sales.Customers
ORDER BY CASE WHEN Score IS NULL THEN 1 ELSE 0 END,SCORE ASC

vi. NULLIF --> syntax  NULLIF(value1,value2) ====> if value1 and value2 are equal it populates NULL else value1

SELECT
Quantity,
Sales,
Sales/NULLIF(Quantity,0) as "revenue"  --Replacing 0 with NULLs
FROM
Sales.Orders

vii. IS NULL & IS NOT NULL  ===> IS NULL --> returns True if null else false
syntax:- value IS NULL or value IS NOT NULL
example:- shipping_address IS NULL    or shipping_address IS NOT NULL

used for searching missing values 

SELECT
*
FROM
Sales.Customers
WHERE score IS NULL


SELECT
*
FROM
Sales.Customers
WHERE score IS NOT NULL


LEFT ANTI JOIN :- left outer join + IS NULL
RIGHT ANTI JOIN:- right outer join + IS NULL

--LIST ALL DETAILS OF CUSTOMERS WHO HAS NOT PLACED ORDERS

SELECT 
c.*,
s.*
FROM 
Sales.Customers c
LEFT OUTER JOIN 
Sales.Orders s ON c.CustomerID=s.CustomerID
WHERE s.CustomerID IS NULL


NULL/empty/Blank ---

WITH ORDERS AS
(
select 1 as id, 'A' as val UNION
SELECT 2,NULL UNION
SELECT 3,'' UNION
SELECT 4,' '
)
SELECT ID, val,DATALENGTH(val) FROM ORDERS


Handling NULLs : Data policies 

WITH ORDERS AS
(
select 1 as id, 'A' as val UNION
SELECT 2,NULL UNION
SELECT 3,'' UNION
SELECT 4,' '
)
SELECT ID, val,
TRIM(val) AS POLICY1,
NULLIF(TRIM(val),'') as policy2,
COALESCE(NULLIF(TRIM(val),''),'Unknown') as policy3
FROM ORDERS









